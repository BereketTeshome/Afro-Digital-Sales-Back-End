# General Settings
PORT=5000

# Database Settings
DB_TYPE=mongodb                # Options: mongodb, mysql, firebase, supabase
MONGO_URI=mongodb://localhost:27017/your_database_name
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=your_database_name
SUPABASE_USER=your_supabase_user
SUPABASE_HOST=your_supabase_host
SUPABASE_DB=your_supabase_db
SUPABASE_PASSWORD=your_supabase_password

# Firebase Settings
FIREBASE_CREDENTIAL={"type": "service_account", "project_id": "your_project_id", ...}
FIREBASE_DB_URL=https://your-firebase-db.firebaseio.com
